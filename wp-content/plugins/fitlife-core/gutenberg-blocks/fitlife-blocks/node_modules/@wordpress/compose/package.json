		"@wordpress/keycodes": "^4.49.0",
		"@wordpress/priority-queue": "^3.49.0",
		"@wordpress/private-apis": "^1.49.0",
		"@wordpress/undo-manager": "^1.49.0",
		"change-case": "^4.1.2",
