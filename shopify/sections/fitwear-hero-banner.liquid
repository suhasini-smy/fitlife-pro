{% schema %}
{
  "name": "FitWear Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Train Hard. Wear FitWear."
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Premium sportswear for peak performance"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Button Link"
    },
    {
      "type": "range",
      "id": "overlay",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.4
    }
  ],
  "presets": [
    {
      "name": "FitWear Hero Banner"
    }
  ]
}
{% endschema %}

<style>
.fitwear-hero {
  position: relative;
  height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  color: #fff;
  background-size: cover;
  background-position: center;
}

.fitwear-hero::before {
  content: "";
  position: absolute;
  top:0;
  left:0;
  right:0;
  bottom:0;
  background: rgba(0,0,0,{{ section.settings.overlay }});
}

.fitwear-content {
  position: relative;
  z-index: 2;
}
</style>

<div class="fitwear-hero" style="background-image:url({{ section.settings.bg_image | img_url: 'master' }});">

  <div class="fitwear-content">
    <h1>{{ section.settings.headline }}</h1>
    <p>{{ section.settings.subheading }}</p>

    {% if section.settings.btn_link != blank %}
      <a href="{{ section.settings.btn_link }}" class="btn">
        {{ section.settings.btn_text }}
      </a>
    {% endif %}
  </div>

</div>
